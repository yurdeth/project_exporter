<?php
$basePath = __DIR__;
$showMainPage = true;
$currentUser = null;

if ($loginEnabled) {
    $currentUser = checkAuth();
    if (!$currentUser) {
        $showMainPage = false;
    } else {
        refreshSessionActivity();
    }
}

$folders = [];
if ($showMainPage) {
    foreach (scandir($basePath) as $item) {
        if ($item === '.' || $item === '..' || $item === 'index.php') continue;
        if (is_dir($basePath . DIRECTORY_SEPARATOR . $item)) $folders[] = $item;
    }
    sort($folders);
}
